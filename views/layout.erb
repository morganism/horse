<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= @title ? "#{@title} — Horse Racing" : "Horse Racing Strategy" %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary">
  <div class="container-fluid">
    <a class="navbar-brand fw-bold text-warning" href="/">
      <i class="bi bi-trophy-fill me-1"></i>Horse Racing
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navmenu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navmenu">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info == '/' %>" href="/">
            <i class="bi bi-speedometer2 me-1"></i>Dashboard
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info.start_with?('/races') %>" href="/races">
            <i class="bi bi-flag me-1"></i>Races
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info.start_with?('/horses') %>" href="/horses">
            <i class="bi bi-heart-pulse me-1"></i>Horses
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info.start_with?('/strategies') %>" href="/strategies">
            <i class="bi bi-bar-chart-line me-1"></i>Strategies
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info == '/correlations' %>" href="/correlations">
            <i class="bi bi-diagram-3 me-1"></i>Correlations
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info == '/simulation' %>" href="/simulation">
            <i class="bi bi-play-circle me-1"></i>Simulation
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= 'active' if request.path_info == '/rota' %>" href="/rota">
            <i class="bi bi-list-check me-1"></i>Rota
          </a>
        </li>
      </ul>
      <ul class="navbar-nav">
        <% if logged_in? %>
          <li class="nav-item">
            <span class="nav-link text-muted">
              <i class="bi bi-person-check-fill text-success me-1"></i><%= current_user %>
            </span>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">
              <i class="bi bi-box-arrow-right me-1"></i>Logout
            </a>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>

<div class="container-fluid py-4">
  <% if @flash %>
    <div class="alert alert-<%= @flash[:type] || 'info' %> alert-dismissible fade show" role="alert">
      <%= @flash[:msg] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% end %>
  <%= yield %>
</div>

<footer class="text-center text-muted py-3 border-top border-secondary mt-4">
  <small>Horse Racing Strategy · Simulation Engine v2 · <%= Time.now.strftime('%Y') %></small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
