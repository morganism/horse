<% @title = 'Race Calendar' %>

<%
  require 'date'
  first_day  = Date.new(@year, @month, 1)
  last_day   = Date.new(@year, @month, -1)
  prev_month = first_day - 1
  next_month = last_day  + 1
  real_today = Date.today
  real_today_ds = real_today.iso8601

  # Build lookup: "YYYY-MM-DD" => { race_count:, venues: }
  day_data   = {}
  @race_days.each { |r| day_data[r[:race_date]] = r }

  latest_ds  = @db_latest.iso8601
%>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="fw-bold mb-0">
    <i class="bi bi-calendar3 text-warning me-2"></i>
    <%= first_day.strftime('%B %Y') %>
  </h2>
  <div>
    <a class="btn btn-sm btn-outline-secondary me-1"
       href="/calendar?year=<%= prev_month.year %>&month=<%= prev_month.month %>">
      &laquo; <%= prev_month.strftime('%b') %>
    </a>
    <% if @year != @db_latest.year || @month != @db_latest.month %>
      <a class="btn btn-sm btn-outline-warning me-1" href="/calendar">Sim Latest</a>
    <% end %>
    <% unless @year == real_today.year && @month == real_today.month %>
      <a class="btn btn-sm btn-outline-info me-1"
         href="/calendar?year=<%= real_today.year %>&month=<%= real_today.month %>">
        Today
      </a>
    <% end %>
    <a class="btn btn-sm btn-outline-secondary"
       href="/calendar?year=<%= next_month.year %>&month=<%= next_month.month %>">
      <%= next_month.strftime('%b') %> &raquo;
    </a>
  </div>
</div>

<% if @race_days.empty? && first_day > Date.new(@db_latest.year, @db_latest.month, 1) %>
  <div class="alert alert-info d-flex justify-content-between align-items-center">
    <span>
      <i class="bi bi-pencil-square me-2"></i>
      No sim data for <%= first_day.strftime('%B %Y') %> — click any day to log real race bets.
    </span>
    <a href="/calendar/<%= real_today_ds %>" class="btn btn-sm btn-info">Log today's bets</a>
  </div>
<% elsif @race_days.empty? %>
  <div class="alert alert-secondary">
    No race data for <%= first_day.strftime('%B %Y') %>.
    <a href="/calendar" class="alert-link">Go to sim latest</a> (<%= @db_latest.strftime('%B %Y') %>).
  </div>
<% end %>

<div class="table-responsive">
  <table class="table table-dark table-bordered text-center" style="table-layout:fixed">
    <thead>
      <tr>
        <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |d| %>
          <th class="text-muted small py-1"><%= d %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <%
        start_pad = (first_day.cwday - 1)
        cells = Array.new(start_pad, nil) + (first_day..last_day).to_a
        cells += Array.new((7 - cells.size % 7) % 7, nil)
        rows  = cells.each_slice(7).to_a
      %>
      <% rows.each do |week| %>
        <tr style="height:80px; vertical-align:top">
          <% week.each do |day| %>
            <% if day.nil? %>
              <td class="bg-black opacity-50"></td>
            <% else %>
              <%
                ds         = day.iso8601
                data       = day_data[ds]
                is_latest  = ds == latest_ds
                is_real_today = ds == real_today_ds
                is_beyond  = ds > latest_ds && !is_real_today  # future with no data and not today
                is_past    = ds < latest_ds

                if is_real_today
                  td_class = 'border border-info'
                elsif is_latest
                  td_class = 'border border-warning'
                else
                  td_class = ''
                end
                td_style = is_beyond ? 'opacity:0.45' : ''
              %>
              <td class="<%= td_class %> p-1 position-relative" style="<%= td_style %>">
                <div class="d-flex justify-content-between align-items-start">
                  <span class="small fw-bold <%= is_real_today ? 'text-info' : is_latest ? 'text-warning' : 'text-muted' %>">
                    <%= day.day %>
                  </span>
                  <% if is_real_today %>
                    <span class="badge bg-info text-dark" style="font-size:0.6rem">TODAY</span>
                  <% elsif is_latest %>
                    <span class="badge bg-warning text-dark" style="font-size:0.6rem">SIM</span>
                  <% end %>
                </div>
                <% if data %>
                  <a href="/calendar/<%= ds %>" class="text-decoration-none d-block mt-1">
                    <span class="badge <%= is_latest ? 'bg-warning text-dark' : 'bg-secondary' %> w-100">
                      <i class="bi bi-flag-fill me-1" style="font-size:0.65rem"></i>
                      <%= data[:race_count] %> race<%= data[:race_count].to_i == 1 ? '' : 's' %>
                    </span>
                    <% if data[:venues] %>
                      <small class="text-muted d-block" style="font-size:0.65rem; line-height:1.2; overflow:hidden; white-space:nowrap; text-overflow:ellipsis">
                        <%= data[:venues] %>
                      </small>
                    <% end %>
                  </a>
                <% elsif is_real_today %>
                  <a href="/calendar/<%= ds %>" class="text-decoration-none d-block mt-1">
                    <span class="badge bg-info text-dark w-100" style="font-size:0.65rem">
                      <i class="bi bi-pencil-square me-1"></i>log bets
                    </span>
                  </a>
                <% elsif is_beyond %>
                  <small class="text-muted" style="font-size:0.65rem">no data</small>
                <% end %>
              </td>
            <% end %>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="row mt-3">
  <div class="col-auto small text-muted">
    <span class="badge bg-info text-dark me-1">TODAY</span> Real today — log bets &nbsp;
    <span class="badge bg-warning text-dark me-1">SIM</span> Latest sim day &nbsp;
    <span class="badge bg-secondary me-1">Past</span> Sim race day &nbsp;
    <span class="badge bg-dark border border-secondary">Future</span> Beyond sim range
    <span class="ms-3 text-muted">Sim data ends: <%= @db_latest.strftime('%d %b %Y') %></span>
  </div>
</div>
