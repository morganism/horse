<% @title = @horse[:name] %>

<div class="mb-3">
  <a href="/horses" class="btn btn-sm btn-outline-secondary">← Horses</a>
</div>

<div class="row mb-4">
  <div class="col">
    <h3 class="fw-bold"><%= @horse[:name] %></h3>
    <div class="d-flex gap-3 text-muted">
      <span><i class="bi bi-person me-1"></i>Trainer: <strong class="text-white"><%= @horse[:trainer] %></strong></span>
      <span>Sire: <strong class="text-white"><%= @horse[:sire] %></strong></span>
      <span>Runs: <strong class="text-info"><%= @horse[:total_runs] %></strong></span>
      <span>Wins: <strong class="text-success"><%= @horse[:total_wins] %></strong></span>
    </div>
  </div>
</div>

<!-- Recent runs -->
<div class="card bg-dark border-secondary mb-4">
  <div class="card-header border-secondary">Recent Runs</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-dark table-hover table-sm mb-0">
        <thead>
          <tr>
            <th>Date</th><th>Time</th><th>Venue</th><th>Type</th>
            <th>Going</th><th>Dist</th><th>SP</th><th>Weight</th>
            <th>Jockey</th><th>Pos</th><th>Btn</th>
          </tr>
        </thead>
        <tbody>
          <% @recent_runs.each do |r| %>
            <tr class="<%= r[:position] == 1 ? 'table-success' : '' %>">
              <td><%= r[:race_date] %></td>
              <td><%= r[:race_time] %></td>
              <td><%= r[:venue_name] %></td>
              <td><span class="badge <%= r[:race_type] == 'flat' ? 'bg-info' : 'bg-warning text-dark' %>"><%= r[:race_type] %></span></td>
              <td class="text-muted small"><%= r[:going] %></td>
              <td><%= r[:distance_furlongs] %>f</td>
              <td><%= r[:sp] ? "%.1f" % r[:sp].to_f : '—' %></td>
              <td class="text-muted small"><%= r[:weight_lbs] %>lbs</td>
              <td class="text-muted small"><%= r[:jockey] %></td>
              <td><strong><%= r[:position] || '—' %></strong></td>
              <td class="text-muted small"><%= r[:btn_lengths] ? "%.1f" % r[:btn_lengths].to_f : '—' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- H2H -->
<% if @h2h.any? %>
<div class="card bg-dark border-secondary">
  <div class="card-header border-secondary">Head-to-Head Records</div>
  <div class="card-body p-0">
    <table class="table table-dark table-sm mb-0">
      <thead>
        <tr><th>Opponent</th><th class="text-end">Meetings</th><th class="text-end">Wins</th><th class="text-end">Losses</th></tr>
      </thead>
      <tbody>
        <% @h2h.each do |row| %>
          <% is_a = row[:horse_a] == @horse[:name] %>
          <% opponent = is_a ? row[:horse_b] : row[:horse_a] %>
          <% wins = is_a ? row[:horse_a_ahead] : row[:horse_b_ahead] %>
          <% losses = row[:meetings] - wins %>
          <tr>
            <td><a href="/horses?search=<%= URI.encode_www_form_component(opponent) %>" class="text-decoration-none"><%= opponent %></a></td>
            <td class="text-end"><%= row[:meetings] %></td>
            <td class="text-end text-success"><%= wins %></td>
            <td class="text-end text-danger"><%= losses %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>
